# Miabi configuration (copy to .env for local dev)
#
# PRODUCTION: when MIABI_ENV is not "dev", Miabi refuses to start until these are
# overridden from their defaults — MIABI_JWT_SECRET, MIABI_ENCRYPTION_KEY,
# MIABI_ADMIN_PASSWORD, and MIABI_CORS_ORIGINS (must be an explicit allowlist,
# not "*"). Without an encryption key, secrets would be stored unencrypted.

# Server
MIABI_ENV=dev
MIABI_PORT=9000
MIABI_DEV_MODE=true
MIABI_CORS_ORIGINS=*

# Security
MIABI_JWT_SECRET=change-me-in-production
# Master key (KEK). It now wraps each workspace's own data-encryption key (DEK)
# rather than encrypting secrets directly; per-workspace DEKs encrypt the data.
# Keep it safe and backed up — losing it makes every workspace key unrecoverable.
MIABI_ENCRYPTION_KEY=
# Per-workspace key auto-rotation (off by default). When on, a workspace's key is
# rotated — re-encrypting its secrets — once its active key is older than
# MIABI_KEY_ROTATE_MONTHS. Admins can always rotate on demand from the workspace
# admin page regardless of this toggle.
MIABI_KEY_AUTO_ROTATE=false
MIABI_KEY_ROTATE_MONTHS=6

# Initial platform admin, seeded on first boot (owns the Platform System
# workspace). Ignored once any user exists. Change the password after first login.
MIABI_ADMIN_EMAIL=admin@example.com
MIABI_ADMIN_PASSWORD=admin1234

# Database (PostgreSQL)
MIABI_DB_HOST=localhost
MIABI_DB_PORT=5432
MIABI_DB_USER=miabi
MIABI_DB_PASSWORD=miabi
MIABI_DB_NAME=miabi
MIABI_DB_SSL_MODE=disable
# MIABI_DB_URL=postgres://user:pass@host:5432/db?sslmode=disable

# Redis (cache + asynq queue)
MIABI_REDIS_ADDR=localhost:6379
MIABI_REDIS_PASSWORD=
# Redis database index. Must match Goma Gateway's GOMA_REDIS_DB for Workspace
# Analytics to work (Goma writes the event stream; Miabi reads it).
MIABI_REDIS_DB=0

# Worker
MIABI_WORKER_CONCURRENCY=10
MIABI_WORKER_MAX_RETRIES=5

# Log store — deploy, pipeline, job, and backup logs are externalized out of
# Postgres into the filesystem backend once a run is terminal, keeping only a
# bounded tail in the DB. Mount MIABI_LOG_DIR as a volume so logs survive restarts;
# if you run a separate `worker` service, mount the SAME volume there so the panel
# can read the logs the worker writes. Set MIABI_LOG_BACKEND=off to keep only the
# DB tail. Defaults shown — uncomment to override.
# MIABI_LOG_BACKEND=filesystem        # filesystem | off
# MIABI_LOG_DIR=/var/lib/miabi/logs
# MIABI_LOG_RETENTION_DAYS=30         # 0 = keep forever
# MIABI_LOG_MAX_BYTES=33554432        # per-log cap (32 MiB); middle-truncated past it
# MIABI_LOG_TAIL_BYTES=16384          # bounded tail kept in the DB (16 KiB)
# MIABI_LOG_COMPRESSION=gzip          # gzip | none

# Container security profile (OpenShift-style "run as non-root").
# When a workspace's plan selects the "restricted" profile — or
# MIABI_FORCE_NON_ROOT_USER forces it globally — application and job
# containers run as MIABI_RESTRICTED_UID:0 with no-new-privileges and NET_RAW
# dropped, instead of the image's default user. RESTRICTED_UID is the platform
# non-root UID (GID is always 0). SECURITY_INIT_IMAGE is the tiny image used to
# chown a restricted app's managed volumes to that UID so it can still write.
MIABI_RESTRICTED_UID=100000
MIABI_FORCE_NON_ROOT_USER=false
MIABI_SECURITY_INIT_IMAGE=busybox:latest

# Docs & metrics
MIABI_OPENAPI_DOCS=true
MIABI_METRICS_ENABLED=true

# Public URLs (how clients/nodes reach this control plane from outside)
# MIABI_API_URL is the panel's externally reachable base URL, e.g.
# https://miabi.example.com. MIABI_WEB_URL is the web UI URL (defaults to the
# API URL when unset).
MIABI_API_URL=
MIABI_WEB_URL=

# Platform notification email (SMTP). When set, Miabi sends its own emails —
# password resets, workspace invitations, and new-user welcomes — via this
# server. Leave MIABI_SMTP_HOST/FROM empty to disable (those emails are then
# silently skipped). MIABI_APP_NAME is the product name shown in the emails;
# action links are built on MIABI_WEB_URL, so set that for working links.
# MIABI_SMTP_ENCRYPTION is one of: none, starttls, ssl.
MIABI_APP_NAME=Miabi
MIABI_SMTP_HOST=
MIABI_SMTP_PORT=587
MIABI_SMTP_USERNAME=
MIABI_SMTP_PASSWORD=
MIABI_SMTP_FROM=
MIABI_SMTP_ENCRYPTION=starttls

# Goma Gateway (reverse proxy; owns TLS/ACME). Miabi drives Goma purely through
# its watched file-provider directory — it writes route/middleware files there and
# Goma hot-reloads them, so there's no API endpoint or token to configure.
# MIABI_GOMA_PROVIDER_DIR is that directory (routes/middlewares are written here).
MIABI_GOMA_PROVIDER_DIR=
# Shared passphrase that makes Goma Gateway encrypt sensitive parts of its config
# (middleware rules and inline TLS certificate/key material) at rest. When set,
# Miabi injects this same value into every edge-gateway node it deploys (as the
# gateway container's GOMA_CONFIG_ENCRYPTION_KEY) and must also be set on the
# local Goma here so they match. Empty disables config encryption.
GOMA_CONFIG_ENCRYPTION_KEY=
# Shared Docker network that Goma Gateway and all app containers join so the
# proxy can reach app backends (Goma must also be attached to it). Default: miabi
MIABI_PROXY_NETWORK=miabi
# Managed network subnet pool. Miabi carves a unique subnet out of this CIDR for
# every Docker network it creates (workspace/stack/overlay) and passes it as
# explicit IPAM, instead of Docker's small built-in default-address-pools (which
# exhaust with "all predefined address pools have been fully subnetted"). The
# default base (10.64.0.0/12) avoids common Kubernetes CNI, Docker, and
# LAN/VPN/Tailscale ranges. The default /12 split into /24s yields 4096 networks;
# pick a base that doesn't overlap your own host/LAN/VPN ranges.
# Defaults: 10.64.0.0/12, 24
MIABI_NETWORK_POOL_CIDR=10.64.0.0/12
MIABI_NETWORK_SUBNET_PREFIX=24
# Cadence (minutes) of the managed-DNS reconcile sweep, which re-asserts the
# records Miabi created via connected DNS providers and refreshes their status.
# Default: 30
MIABI_DNS_RECONCILE_MINUTES=30

# External access (one-click public URLs). MIABI_EXTERNAL_BASE_DOMAIN is the
# wildcard base domain apps are published under, e.g. "apps.example.com" (point
# DNS *.apps.example.com at the gateway). MIABI_EXTERNAL_BASE_PROVIDER is the Goma
# certManager provider used for those routes' certificates ("" = gateway default).
# When set, these are authoritative and override the admin Settings UI on boot;
# leave empty to manage them from the UI instead.
MIABI_EXTERNAL_BASE_DOMAIN=
MIABI_EXTERNAL_BASE_PROVIDER=

# Edge-gateway nodes: a node set to "edge-gateway" runs its own Goma Gateway,
# which pulls its routes/middlewares from this control plane's HTTP provider.
# MIABI_CONTROL_URL is the base URL that node gateways use to reach the
# control plane (must be reachable FROM the node, e.g. https://miabi.example.com).
# Required to deploy an edge gateway; falls back to MIABI_API_URL when unset.
MIABI_CONTROL_URL=
# Goma image deployed on edge-gateway nodes, and the ACME contact email it uses.
# MIABI_ACME_EMAIL is also the contact for Miabi-issued managed (DNS-01) certs.
MIABI_NODE_GATEWAY_IMAGE=jkaninda/goma-gateway:latest
MIABI_ACME_EMAIL=admin@example.com
# Managed certificates (Miabi issues ACME DNS-01 certs via a connected DNS
# provider, stored in workspace Certificates). ACME CA directory — empty = Let's
# Encrypt production; set to the LE staging directory for testing so issuance
# never burns prod rate limits. CERT_RENEW_DAYS = renew window before expiry.
MIABI_ACME_DIRECTORY_URL=
MIABI_CERT_RENEW_DAYS=30

# Built-in Docker registry (first-party, multi-tenant). Disabled by default.
# Local (filesystem) storage is free; S3/MinIO storage requires an Enterprise
# license. When any value here is set it is authoritative on boot (overrides the
# admin Settings UI), like MIABI_EXTERNAL_BASE_DOMAIN.
#   HOST         docker login target; defaults to registry.<EXTERNAL_BASE_DOMAIN>.
#   STORAGE      filesystem | s3   (blank = filesystem)
#   IMAGE        override the registry image (also settable via the image catalog)
#   AUTH_URL     address the gateway's forwardAuth calls to reach this control
#                plane (e.g. http://miabi:9000); falls back to MIABI_CONTROL_URL.
#   PLATFORM_TOKEN  shared secret the build/deploy worker uses to push/pull built
#                images so other nodes can pull them (multi-node). Empty disables
#                build distribution.
MIABI_REGISTRY_ENABLED=false
MIABI_REGISTRY_HOST=
MIABI_REGISTRY_STORAGE=filesystem
MIABI_REGISTRY_IMAGE=registry:3
MIABI_REGISTRY_AUTH_URL=
MIABI_REGISTRY_PLATFORM_TOKEN=
# S3/MinIO storage (Enterprise). FORCE_PATH_STYLE is required by MinIO.
MIABI_REGISTRY_S3_ENDPOINT=
MIABI_REGISTRY_S3_BUCKET=
MIABI_REGISTRY_S3_REGION=
MIABI_REGISTRY_S3_ACCESS_KEY=
MIABI_REGISTRY_S3_SECRET_KEY=
MIABI_REGISTRY_S3_FORCE_PATH_STYLE=false

# Enterprise license (unlocks paid features; community runs without one).
# Provide the signed license as a file path or inline; PUBLIC_KEY verifies it.
MIABI_LICENSE_PUBLIC_KEY=
MIABI_LICENSE_FILE=

# Enforcement toggles. PLAN_ENFORCEMENT applies per-workspace plan quotas;
# SECURITY_ENFORCEMENT guards managed containers from admin stop/remove and
# similar break-glass actions (disable only deliberately).
MIABI_PLAN_ENFORCEMENT=false
MIABI_SECURITY_ENFORCEMENT=true

# Source builds (Git apps) run on a runner, not on the node. This is the hard
# per-build deadline the runner dispatcher enforces (0 = none). Per-build memory/
# CPU caps and the pack Docker API version now live on the runner.
MIABI_BUILD_TIMEOUT_MINUTES=30

# Runners: dedicated build/pipeline machines that keep build load off the app
# hosting nodes. Every build runs on a registered runner — there is no on-node or
# in-process fallback. Add a runner from Settings → Runners (or an admin-managed
# shared runner). RUNNER_WAIT_TIMEOUT_MINUTES bounds how long a build waits for an
# available runner before it fails ("no runner became available"); until then the
# run stays pending and is re-checked periodically.
# JOB_API_TOKEN_ENABLED injects the scoped MIABI_JOB_TOKEN callback credential
# into runner jobs (registry credentials are injected regardless).
MIABI_RUNNER_WAIT_TIMEOUT_MINUTES=30
MIABI_JOB_API_TOKEN_ENABLED=true
# The miabi-runner image shown in the runner enrollment command (docker run …).
MIABI_RUNNER_IMAGE=miabi/runner:latest

# Host port bindings: the inclusive range apps may request for host-published
# ports. Keep MIN above privileged ports unless you intend otherwise.
MIABI_HOST_PORT_MIN=1024
MIABI_HOST_PORT_MAX=65535

# On-demand database port-forwards (the socat relay). BIND_ADDR is where the
# forward listens on the node (127.0.0.1 = local only); ADVERTISE_HOST is the
# host shown to the user; TTL bounds a session; RELAY_IMAGE is the socat image.
MIABI_FORWARD_BIND_ADDR=127.0.0.1
MIABI_FORWARD_ADVERTISE_HOST=
MIABI_FORWARD_TTL_MINUTES=30
MIABI_FORWARD_RELAY_IMAGE=alpine/socat:latest

# Metrics retention + scrape cadence for the built-in container metrics.
MIABI_METRICS_RETENTION_HOURS=24
MIABI_METRICS_SCRAPE_SECONDS=60

# --- Workspace Analytics (HTTP traffic / performance / web) ------------------
# Rolls up Goma Gateway's per-request event stream into minute buckets. Goma must
# have GOMA_ANALYTICS_ENABLED=true and write to the same Redis DB (MIABI_REDIS_DB).
MIABI_ANALYTICS_ENABLED=true
# Redis stream Goma publishes request events to (must match Goma's GOMA_ANALYTICS_STREAM).
MIABI_ANALYTICS_STREAM=goma:analytics
# How often (seconds) the consumer persists closed minute buckets.
MIABI_ANALYTICS_FLUSH_SECONDS=15
# Rollup retention (days). Community is capped at 7; extended retention is Enterprise.
MIABI_ANALYTICS_RETENTION_DAYS=90

# GeoIP: enables the "requests by country" map + geo-block middleware. During a
# stack install Miabi auto-downloads GeoLite2-Country.mmdb into the gateway.
# Set MIABI_GEOIP=off to skip the download (bring your own .mmdb), or override the URL.
MIABI_GEOIP=on
MIABI_GEOIP_URL=https://github.com/P3TERX/GeoLite.mmdb/releases/download/2026.07.16/GeoLite2-Country.mmdb

# Marketplace template catalog source (signed export.json).
MIABI_MARKETPLACE_URL=https://github.com/miabi-io/marketplace/releases/latest/download/export.json
# MIABI_MARKETPLACE_URL=https://marketplace.miabi.io

# Account deletion grace window (days) before a scheduled account is purged.
MIABI_DELETION_GRACE_DAYS=7

# Max size (MB) of a backup artifact accepted for restore.
MIABI_RESTORE_MAX_MB=1024

# Allow outbound webhooks to private/loopback targets (SSRF guard). Keep false in
# production unless you trust every configured webhook URL.
MIABI_WEBHOOK_ALLOW_PRIVATE_TARGETS=false

# Host /proc mount (for node host metrics when running in a container).
MIABI_HOST_PROC=/host/proc

# Built web UI directory to serve as an SPA (single-binary deploys). Empty = the
# API runs headless (web served elsewhere).
MIABI_WEB_DIR=

# Permit booting a binary older than the version recorded by the last run.
MIABI_ALLOW_DOWNGRADE=false
