# ─────────────────────────────────────────────────────────────────────────────
# Miabi — production configuration
#
# Copy to .env and fill in the REQUIRED values below, then `docker compose up -d`
# (or run ./install.sh, which generates the secrets for you).
#
#   cp .env.example .env
#   # generate a secret:  openssl rand -hex 32
#
# Only the values under "REQUIRED" must be set. Everything else has a sensible
# default and is shown commented out with its default — uncomment to override.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Public address of the panel.
#   MIABI_DOMAIN  — the bare host Goma routes and issues a TLS certificate for.
#   MIABI_WEB_URL — the full URL Miabi advertises (CORS, API docs, and the
#                   control URL remote nodes connect back to).
MIABI_DOMAIN=miabi.example.com
MIABI_WEB_URL=https://miabi.example.com

# Email Let's Encrypt registers for ACME certificates (Goma + node gateways).
MIABI_ACME_EMAIL=admin@example.com

# Secrets — no defaults; generate each with: openssl rand -hex 32
# (install.sh fills these in for you on a fresh install.)
MIABI_DB_PASSWORD=
MIABI_REDIS_PASSWORD=
MIABI_JWT_SECRET=
MIABI_ENCRYPTION_KEY=

# The platform admin, seeded into the database on first boot. Miabi refuses to
# start outside dev while the password is empty or the built-in default, so both
# are REQUIRED. Log in with these, then change the password from the UI.
MIABI_ADMIN_EMAIL=admin@example.com
MIABI_ADMIN_PASSWORD=

# Self-service password reset (the "forgot password" flow). A critical auth
# control, so it is fixed at boot — set false and restart to disable it.
MIABI_PASSWORD_RESET_ENABLED=true

# Host's docker group GID, so the non-root container can read the Docker socket:
#   echo "DOCKER_GID=$(stat -c '%g' /var/run/docker.sock)" >> .env
DOCKER_GID=999

# ── Database (optional) ──────────────────────────────────────────────────────
MIABI_DB_USER=miabi
MIABI_DB_NAME=miabi
# MIABI_DB_SSL_MODE=disable
# Use a full DSN instead of the discrete settings above (overrides them):
# MIABI_DB_URL=postgres://user:pass@host:5432/miabi?sslmode=disable

# ── Images (optional) ────────────────────────────────────────────────────────
# install.sh writes both of these, pinning the exact versions the release was
# tested with, and rewrites them on every re-run (that is how you upgrade).
# Point either at a different repository — a private mirror, a locally built
# image — and the installer will leave your value alone.
#
# Image tags carry no leading "v": git tag v1.0.0 → miabi/miabi:1.0.0.
MIABI_IMAGE=miabi/miabi:latest
# GOMA_IMAGE pins the local gateway service AND the gateways Miabi provisions on
# remote nodes (it feeds MIABI_NODE_GATEWAY_IMAGE), so both always run the same
# Goma version. A per-node override is still available from the UI.
GOMA_IMAGE=jkaninda/goma-gateway:latest
# Optional. Encrypts the sensitive parts of gateway config (middleware rules +
# TLS) at rest: Miabi encrypts, Goma decrypts. Passed to BOTH the miabi and
# gateway services, so one value here covers both (Miabi also injects it into
# remote edge gateways). Off (empty) by default; independent of
# MIABI_ENCRYPTION_KEY. Generate with: openssl rand -hex 32
# GOMA_CONFIG_ENCRYPTION_KEY=
# The image in the runner enrollment command. miabi/runner has its own release
# cadence (0.0.x while the panel is 1.0.x) — never assume it shares MIABI_IMAGE's
# tag; miabi/runner:1.0.0 does not exist.
RUNNER_IMAGE=miabi/runner:latest

# ── Outbound email / SMTP (optional) ─────────────────────────────────────────
# Used for invitations, password resets, and notifications. Without it those
# emails are skipped. MIABI_SMTP_ENCRYPTION is one of: starttls | tls | none.
# MIABI_SMTP_HOST=
# MIABI_SMTP_PORT=587
# MIABI_SMTP_USERNAME=
# MIABI_SMTP_PASSWORD=
# MIABI_SMTP_FROM=Miabi <no-reply@example.com>
# MIABI_SMTP_ENCRYPTION=starttls

# ── One-click external URLs (optional) ───────────────────────────────────────
# A wildcard base domain so apps get a public URL at <label>.<base-domain>
# without configuring a domain each time. Requires a DNS provider connected in
# the UI (or the named provider here) to create the wildcard record.
# MIABI_EXTERNAL_BASE_DOMAIN=apps.example.com
# MIABI_EXTERNAL_BASE_PROVIDER=

# ── Container security profile (optional) ────────────────────────────────────
# Force every app & job container to run as a non-root UID (no-new-privileges,
# NET_RAW dropped) regardless of plan. Otherwise it is opt-in per workspace plan
# ("restricted").
# MIABI_FORCE_NON_ROOT_USER=true
# MIABI_RESTRICTED_UID=100000

# ── Enforcement switches (optional) ──────────────────────────────────────────
# Two similar names, unrelated jobs. Both ON by default; disabling either
# removes a protection.
#
# PLAN_ENFORCEMENT gates per-workspace quotas and capability gates. Set it false
# and every quota check passes and every capability is allowed, whatever plan a
# workspace is on.
# MIABI_PLAN_ENFORCEMENT=true
#
# SECURITY_ENFORCEMENT stops a platform admin from raw-stopping or removing a
# Miabi-managed container (apps, databases, gateways) from the admin node view;
# those are managed through the resource that owns them. ON by default. Set it
# false only as a break-glass escape hatch.
# MIABI_SECURITY_ENFORCEMENT=true

# ── Storage usage measurement (optional) ─────────────────────────────────────
# A periodic sweep measures each volume's real on-disk usage (docker system df)
# and caches it, so the UI shows declared-vs-used without a live filesystem walk
# on every read. ON by default. Set false to skip the walks entirely (the UI
# then shows declared sizes only). Raise the interval on nodes with many/large
# volumes where the df walk is heavy.
# MIABI_STORAGE_USAGE_ENABLED=true
# MIABI_STORAGE_USAGE_MINUTES=30

# ── Background worker (optional) ─────────────────────────────────────────────
# The worker runs embedded in the main process by default. Tune its throughput,
# or run a separate `command: ["worker"]` service to scale it out.
# MIABI_WORKER_CONCURRENCY=10
# MIABI_WORKER_MAX_RETRIES=5

# ── Image builds (git-source apps, optional) ─────────────────────────────────
# How long an in-platform image build may run before it is aborted.
# MIABI_BUILD_TIMEOUT_MINUTES=30

# ── Metrics (optional) ───────────────────────────────────────────────────────
# Prometheus /metrics and the history scraper are OFF by default; /metrics is
# not served until you set this true.
# MIABI_METRICS_ENABLED=false
# MIABI_METRICS_SCRAPE_SECONDS=60
# MIABI_METRICS_RETENTION_HOURS=24

# ── Log level (optional) ─────────────────────────────────────────────────────
# How chatty Miabi's OWN logs are (the server and the worker; distinct from the
# execution-log storage below). Unset follows the environment: debug in dev, info
# in production. A value Miabi does not recognize is a startup error rather than a
# silent fallback, so a typo cannot leave you watching for logs that never come.
# `off` is not offered: the logging library cannot honour it for the calls Miabi
# makes, and a switch that appears to silence logs while they keep coming is worse
# than none. Use `error` for near-silence.
# MIABI_LOG_LEVEL=info                    # debug | info | warn | error

# ── Log storage (optional) ───────────────────────────────────────────────────
# Deploy, pipeline, job, and backup logs are externalized out of Postgres into a
# shared store, keeping only a bounded tail in the database. The default
# filesystem backend writes to MIABI_LOG_DIR — mount it as a volume (the compose
# files ship a `miabi-logs` volume). A standalone `worker` service must mount the
# SAME directory to share logs. Set the backend to `off` to keep the old
# DB-tail-only behavior.
# MIABI_LOG_BACKEND=filesystem            # filesystem | off
# MIABI_LOG_DIR=/var/lib/miabi/logs
# MIABI_LOG_RETENTION_DAYS=30             # 0 = keep forever
# MIABI_LOG_MAX_BYTES=33554432            # per-log cap (32 MiB); middle-truncated past it
# MIABI_LOG_TAIL_BYTES=16384              # bounded tail kept in the DB (16 KiB)
# MIABI_LOG_COMPRESSION=gzip              # gzip | none

# ── TLS / certificate management (optional) ──────────────────────────────────
# Renew managed (DNS-01) certs this many days before expiry. Point
# ACME_DIRECTORY_URL at a staging CA while testing to avoid rate limits.
# MIABI_CERT_RENEW_DAYS=30
# MIABI_DNS_RECONCILE_MINUTES=30
# MIABI_ACME_DIRECTORY_URL=

# ── Encryption key rotation (optional) ───────────────────────────────────────
# MIABI_KEY_AUTO_ROTATE=false
# MIABI_KEY_ROTATE_MONTHS=6

# ── Built-in container registry (optional, advanced) ─────────────────────────
# Enable an in-platform OCI registry. S3 storage is an Enterprise feature.
#
# Leave these commented to manage the registry from the UI (Settings → Registry).
# Setting any of them is a ONE-WAY OVERRIDE: the value wins over whatever the UI
# stores, so MIABI_REGISTRY_ENABLED=true cannot then be turned off in the UI.
# MIABI_REGISTRY_ENABLED=false is not an off switch — it is simply ignored.
#
# MIABI_REGISTRY_HOST needs its own DNS A record so Goma can issue a certificate
# for it. Left empty while enabled, the host falls back to
# registry.<MIABI_EXTERNAL_BASE_DOMAIN>; with neither, image distribution fails.
# MIABI_REGISTRY_ENABLED=false
# MIABI_REGISTRY_HOST=registry.example.com
# MIABI_REGISTRY_STORAGE=filesystem        # filesystem | s3
# MIABI_REGISTRY_S3_ENDPOINT=
# MIABI_REGISTRY_S3_BUCKET=
# MIABI_REGISTRY_S3_REGION=
# MIABI_REGISTRY_S3_ACCESS_KEY=
# MIABI_REGISTRY_S3_SECRET_KEY=
# MIABI_REGISTRY_S3_FORCE_PATH_STYLE=false

# ── Networking (optional) ────────────────────────────────────────────────────
# CIDR of the shared `miabi` bridge network that Goma Gateway and every routed
# app/database container join. install.sh creates this network up front as an
# EXTERNAL network with this subnet, so it survives `docker compose down` and
# never falls back to Docker's small built-in address pool (which caps a plain
# network's IPs and how many networks a host can have). Give it plenty of room on
# a busy multi-tenant host; must NOT overlap MIABI_NETWORK_POOL_CIDR (the pool
# Miabi carves per-workspace/db/stack /24s from, default 10.64.0.0/12) or your LAN.
# MIABI_NETWORK_CIDR=10.63.0.0/16

# Address pool Miabi carves a /MIABI_NETWORK_SUBNET_PREFIX network from for every
# workspace/user/stack network it creates itself — kept separate from Docker's
# default pool so many tenants don't exhaust it. Must not overlap MIABI_NETWORK_CIDR.
# MIABI_NETWORK_POOL_CIDR=10.64.0.0/12
# MIABI_NETWORK_SUBNET_PREFIX=24

# ── Advanced (optional) ──────────────────────────────────────────────────────
# Days an admin-scheduled account deletion waits before the account and all its
# data are permanently purged. The account is disabled during this grace window
# and the admin can cancel.
# MIABI_DELETION_GRACE_DAYS=7

# Max size (MB) accepted for a database/volume restore upload.
# MIABI_RESTORE_MAX_MB=1024

# Allow webhooks to target private/loopback addresses (off by default for SSRF
# safety; enable only on trusted internal networks).
# MIABI_WEBHOOK_ALLOW_PRIVATE_TARGETS=false

# Serve the OpenAPI docs UI at /docs.
# MIABI_OPENAPI_DOCS=true

# Once a day, ask GitHub whether a newer Miabi release exists and show platform
# admins a notice. Nothing about this install is sent: an unauthenticated GET to
# api.github.com, identified only by "User-Agent: miabi/<version>". Miabi never
# upgrades itself — the notice links to the release notes. Set false on
# air-gapped hosts or to avoid the outbound call entirely.
# MIABI_UPDATE_CHECK=true

# Host procfs path for real host CPU/memory on the admin Node page. The compose
# binds /proc:/host/proc:ro; leave the default to use it. Without the bind, Miabi
# reads /proc (still host stats inside the container) or the container aggregate.
# MIABI_HOST_PROC=/host/proc
